NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/wealthlens
MONGO_URI_TEST=mongodb://localhost:27017/wealthlens_test
REDIS_URL=redis://localhost:6379
JWT_PRIVATE_KEY=your-rsa-private-key-base64
JWT_PUBLIC_KEY=your-rsa-public-key-base64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
COOKIE_SECRET=your-32-char-random-string
ALLOWED_ORIGINS=http://localhost:5173
MAX_IMPORT_FILE_SIZE_MB=10
CACHE_TTL_SECONDS=300
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
